# Planner 2.0 — example environment configuration.
# Copy to .env.local and fill in real values. Never commit real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — bypasses RLS; server/cron use only. Keep secret.
SUPABASE_SERVICE_KEY=

# --- NextAuth ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- OpenAI (AI day-planner, Wave 8; optional/feature-flagged) ---
OPENAI_API_KEY=

# --- Microsoft Graph / Outlook sync ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_USER_EMAIL=
OUTLOOK_CLIENT_STATE=
OUTLOOK_RENEW_BEFORE_MIN=
OUTLOOK_SUBSCRIPTION_DURATION_MIN=
OUTLOOK_SYNC_JOB_SECRET=
OUTLOOK_WEBHOOK_URL=

# --- Daily task email / morning digest ---
DAILY_TASK_EMAIL_FROM=
DAILY_TASK_EMAIL_TO=
DIGEST_USER_EMAIL=
DAILY_TASK_EMAIL_TIME_ZONE=Europe/London
# Base app URL used for the digest's "Open Planner" link and signed action links; falls back to NEXTAUTH_URL.
DIGEST_DASHBOARD_URL=

# --- Signed email actions (Wave 8) ---
# HMAC secret for tap-to-confirm email action links; if unset, action buttons are not rendered (feature off).
EMAIL_ACTION_SECRET=
